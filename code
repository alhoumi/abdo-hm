  function buildDots() {
    const c = document.getElementById('chapter-dots');
    c.innerHTML = '';
    pages.forEach((p, i) => {
      const d = document.createElement('button');
      d.className = 'ch-dot' + (i === 0 ? ' active' : '');
      d.title = p.label;
      d.onclick = () => goTo(i);
      c.appendChild(d);
    });
  }

  function goTo(idx, animate) {
