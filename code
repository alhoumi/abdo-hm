    const page = document.getElementById('book-page');
    page.style.opacity = '0';
    setTimeout(() => {
      page.innerHTML = pages[idx].html;
      page.style.opacity = '1';
      document.getElementById('page-label').textContent = (idx + 1) + ' / ' + pages.length + '  ·  ' + pages[idx].label;
      document.getElementById('progress-bar').style.width = ((idx + 1) / pages.length * 100) + '%';
      document.getElementById('btn-prev').disabled = idx === 0;
      document.getElementById('btn-next').disabled = idx === pages.length - 1;
      document.querySelectorAll('.ch-dot').forEach((d, i) => d.classList.toggle('active', i === idx));
      document.getElementById('book-reader').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 250);
  }

  function nextPage() { if (current < pages.length - 1) goTo(current + 1); }
  function prevPage() { if (current > 0) goTo(current - 1); }

  buildDots();
  goTo(0);
  </script>


